# ============================================
# Deployer .env — скопируй в .env.deployer
# ============================================

# Случайный токен для авторизации webhook
# Генерируй: openssl rand -hex 32
DEPLOY_TOKEN=CHANGE_ME_RANDOM_TOKEN

# GitHub PAT с scope: read:packages
# Создавай: https://github.com/settings/tokens
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Опционально: Telegram bot webhook для уведомлений о деплое
# LOG_WEBHOOK=https://api.telegram.org/bot<BOT_TOKEN>/sendMessage?chat_id=<CHAT_ID>
